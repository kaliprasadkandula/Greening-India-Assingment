# PostgreSQL
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow

# API
NODE_ENV=production
PORT=4000
# Docker: use 'db' as host (docker service name). Local dev: use 'localhost'
DATABASE_URL=postgresql://taskflow:taskflow@db:5432/taskflow

# JWT — generate a strong random secret, never commit the real value
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Logging
LOG_LEVEL=info

# Frontend (browser-facing API URL — must be reachable from the user's browser)
VITE_API_URL=http://localhost:4000
